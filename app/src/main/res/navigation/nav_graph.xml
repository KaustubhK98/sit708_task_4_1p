<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/nav_graph"
    app:startDestination="@id/eventListFragment">

    <fragment
        android:id="@+id/eventListFragment"
        android:name="com.example.eventplanner.EventListFragment"
        android:label="Event List">

        <action
            android:id="@+id/action_eventListFragment_to_addEditEventFragment"
            app:destination="@id/addEditEventFragment" />

    </fragment>

    <fragment
        android:id="@+id/addEditEventFragment"
        android:name="com.example.eventplanner.UpdateEventFragment"
        android:label="Add Event">

        <argument
            android:name="eventId"
            android:defaultValue="-1"
            app:argType="integer" />

    </fragment>

</navigation>